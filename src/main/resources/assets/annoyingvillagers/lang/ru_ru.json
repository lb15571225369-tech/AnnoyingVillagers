  "skill.annoyingvillagers.null_weapon": "§7Магистр Инструментов§r",
  "skill.annoyingvillagers.obsidian_sledgehammer": "§5Метеоритный Удар§r",
  "skill.annoyingvillagers.obsidian_weapon": "§7Обсидиановая Стена§r",
  "skill.annoyingvillagers.shadow_obsidian_pillar": "§7Колючая Тропинка§r",
